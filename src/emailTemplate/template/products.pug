if order.products && order.products.length > 0
	h2 Položky

	each productItem in order.products
		.product
			p(style="margin-bottom: 4px;")
				span.product-prefix -
				span.product-title= productItem.title
				span.product-divider
				span #{"("}
				span x
				strong.product-count= productItem.quantity
				span #{")"}

			if productItem.modifiers && productItem.modifiers.length > 0
				each modifierItem in productItem.modifiers
					p.product-modifier
						span.product-prefix --
						span.product-title= modifierItem.title

					if modifierItem.subModifier
						p.product-submodifier
							span.product-prefix --
							span.product-title= modifierItem.subModifier.title
